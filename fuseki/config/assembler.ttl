PREFIX :       <http://base/#>
PREFIX fuseki: <http://jena.apache.org/fuseki#>
PREFIX ja:     <http://jena.hpl.hp.com/2005/11/Assembler#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
PREFIX tdb2:   <http://jena.apache.org/2016/tdb#>

# (Usually optional when using the official Fuseki distro, but harmless.)
[] ja:loadClass "org.apache.jena.tdb2.TDB2" .
tdb2:DatasetTDB2 rdfs:subClassOf ja:RDFDataset .

:tdb_dataset_readwrite
    a tdb2:DatasetTDB2 ;
    tdb2:location  "/fuseki/databases/materialsmine" ;
    tdb2:unionDefaultGraph true .

:service_tdb_all  a fuseki:Service ;
    rdfs:label       "TDB2 materialsmine" ;
    fuseki:name      "materialsmine" ;
    fuseki:dataset   :tdb_dataset_readwrite ;

    # Query endpoints
    fuseki:endpoint  [ fuseki:name "query"  ; fuseki:operation fuseki:query  ] ;
    fuseki:endpoint  [ fuseki:name "sparql" ; fuseki:operation fuseki:query  ] ;

    # Update endpoint
    fuseki:endpoint  [ fuseki:name "update" ; fuseki:operation fuseki:update ] ;

    # Graph Store Protocol (read/write & read-only)
    fuseki:endpoint  [ fuseki:name "data"   ; fuseki:operation fuseki:gsp-rw ] ;
    fuseki:endpoint  [                          fuseki:operation fuseki:gsp-rw ] ;
    fuseki:endpoint  [ fuseki:name "get"    ; fuseki:operation fuseki:gsp-r   ] .