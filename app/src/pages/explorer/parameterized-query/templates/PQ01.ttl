@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix sp: <http://spinrdf.org/sp> .
@prefix spin: <http://spinrdf.org/spin#> .
@prefix spl: <http://spinrdf.org/spl#> .
@prefix whyis: <http://vocab.rpi.edu/whyis/> .
@prefix materialsmine_templates: <http://materialsmine.org/query/> .
@prefix mmpq: <http://materialsmine.org/explorer/parameterized_query/>.

materialsmine_templates:PQ01 a whyis:SparqlTemplate;
  spin:labelTemplate "Show me <b>polymer nanocomposite samples</b> containing {?FillerParam} filler surrounded by {?MatrixParam} matrix, along with the {?AmountType} fraction of filler and reported values of {?PropertyType}.";
  sp:text """
PREFIX mm:     <http://materialsmine.org/resource/>
PREFIX schema: <http://schema.org/>
PREFIX sio:    <http://semanticscience.org/resource/>
PREFIX prov:   <http://www.w3.org/ns/prov#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
SELECT DISTINCT
  (STR(?sampleName)              AS ?Sample)
  (LCASE(STR(?fillerName))       AS ?Filler)
  ?FillerAmount
  (STR(?matrixName)              AS ?Matrix)
  ?AttributeValue
  (STR(?unitOfMeasure)           AS ?UnitOfMeasure)
WHERE {
  # --------------------
  # Sample
  # --------------------
  ?sample a mm:MaterialSample ;
          schema:name ?sampleName ;
          mm:hasMaterials ?materials ;
          mm:hasProperties ?props .
  # --------------------
  # Matrix name: prefer StdChemicalName, else ChemicalName
  # --------------------
  ?materials mm:hasMatrix ?matrix .
  ?matrix mm:hasMatrixComponent ?matrixComp .
  OPTIONAL {
    ?matrixComp sio:hasAttribute ?mStdNode .
    ?mStdNode a mm:StdChemicalName ;
              sio:hasValue ?mStdVal .
  }
  OPTIONAL {
    ?matrixComp sio:hasAttribute ?mChemNode .
    ?mChemNode a mm:ChemicalName ;
               sio:hasValue ?mChemVal .
  }
  BIND(COALESCE(?mStdVal, ?mChemVal) AS ?matrixName)
  FILTER(BOUND(?matrixName))
  FILTER(
    LCASE(STR(?MatrixParam)) = "any"
    || LCASE(STR(?matrixName)) = LCASE(STR(?MatrixParam))
  )
  # --------------------
  # Filler name: prefer StdChemicalName, else ChemicalName
  # --------------------
  ?materials mm:hasFiller ?filler .
  ?filler mm:hasFillerComponent ?fillerComp .
  OPTIONAL {
    ?fillerComp sio:hasAttribute ?fStdNode .
    ?fStdNode a mm:StdChemicalName ;
              sio:hasValue ?fStdVal .
  }
  OPTIONAL {
    ?fillerComp sio:hasAttribute ?fChemNode .
    ?fChemNode a mm:ChemicalName ;
               sio:hasValue ?fChemVal .
  }
  BIND(COALESCE(?fStdVal, ?fChemVal) AS ?fillerName)
  FILTER(BOUND(?fillerName))
  FILTER(
    LCASE(STR(?FillerParam)) = "any"
    || LCASE(STR(?fillerName)) = LCASE(STR(?FillerParam))
  )
  # --------------------
  # Filler fraction (parameterized: VolumeFraction, MassFraction, etc.)
  # --------------------
  ?filler mm:hasFillerComposition ?fillerCompn .
  ?fillerCompn sio:hasAttribute ?fractionNode .
  ?fractionNode a ?AmountType ;
                sio:hasValue ?FillerAmount .

  # If you want “reported only”, add:
  # ?fractionNode prov:hadPrimarySource ?src .
  # FILTER(LCASE(STR(?src)) = "reported")
  # --------------------
  # Property (parameterized: GlassTransitionTemperature, etc.)
  # --------------------
  {
    # Thermal path (e.g., GlassTransitionTemperature)
    ?props mm:hasThermalProperty ?propNode .
  }
  UNION
  {
    # Mechanical path (e.g., TensileModulus)
    ?props mm:hasMechanicalProperty ?mechGroup .
    ?mechGroup sio:hasAttribute ?propNode .
  }
  ?propNode a ?PropertyType ;
            sio:hasValue ?AttributeValue .
  OPTIONAL { ?propNode sio:hasUnit ?unitOfMeasure }
}
ORDER BY ?sampleName
""";
  spin:constraint [
    a spl:Argument ;
    sp:varName "FillerParam";
    schema:option [
        rdfs:label "any";
        schema:value "any" ;
        schema:position 1
      ],
      [
        rdfs:label "silica";
        schema:value "Silicon dioxide";
        schema:position 2
      ],
      [
        rdfs:label "multi-wall CNTs";
        schema:value "Multi-wall carbon nanotubes";
        schema:position 3
      ],
      [
        rdfs:label "barium titanate";
        schema:value "Barium titanate";
        schema:position 4
      ],
      [
        rdfs:label "titania";
        schema:value "Titanium dioxide";
        schema:position 5
      ],
      [
        rdfs:label "graphene";
        schema:value "Graphene";
        schema:position 6
      ],
      [
        rdfs:label "carbon black";
        schema:value "Carbon black";
        schema:position 7
      ],
      [
        rdfs:label "alumina";
        schema:value "Aluminium oxide";
        schema:position 8
      ],
      [
        rdfs:label "graphite";
        schema:value "Graphite";
        schema:position 9
      ],
      [
        rdfs:label "silver";
        schema:value "Silver";
        schema:position 10
      ],
      [
        rdfs:label "graphene oxide";
        schema:value "Graphene oxide";
        schema:position 11
      ],
      [
        rdfs:label "zinc oxide";
        schema:value "Zinc oxide";
        schema:position 12
      ],
      [
        rdfs:label "montmorillonite";
        schema:value "Montmorillonite";
        schema:position 13
      ],
      [
        rdfs:label "reduced graphene oxide";
        schema:value "Reduced graphene oxide";
        schema:position 14
      ],
      [
        rdfs:label "single-wall CNTs";
        schema:value "Single-wall carbon nanotubes";
        schema:position 15
      ]
  ],
  [
    a spl:Argument ;
    sp:varName "MatrixParam";
    schema:option [
        rdfs:label "any";
        schema:value "any" ;
        schema:position 1
      ],
      [
        rdfs:label "epoxy";
        schema:value "DGEBA Epoxy Resin";
        schema:position 2
      ],
      [
        rdfs:label "PMMA";
        schema:value "Poly(methyl methacrylate)";
        schema:position 3
      ],
      [
        rdfs:label "polystyrene";
        schema:value "Polystyrene";
        schema:position 4
      ],
      [
        rdfs:label "polyethylene";
        schema:value "Poly(ethylene)";
        schema:position 5
      ],
      [
        rdfs:label "PEG";
        schema:value "Poly(ethylene glycol)";
        schema:position 6
      ],
      [
        rdfs:label "PVDF";
        schema:value "Poly(vinylidene fluoride)";
        schema:position 7
      ],
      [
        rdfs:label "poly(bisphenol A carbonate)";
        schema:value "Poly(bisphenol A carbonate)";
        schema:position 8
      ],
      [
        rdfs:label "silicone";
        schema:value "Silicone rubber";
        schema:position 9
      ],
      [
        rdfs:label "polypropylene";
        schema:value "Poly(propylene)";
        schema:position 10
      ],
      [
        rdfs:label "cycloaliphatic epoxy";
        schema:value "Cycloaliphatic Epoxy Resin";
        schema:position 11
      ],
      [
        rdfs:label "P2VP";
        schema:value "Poly(2-vinyl pyridine)";
        schema:position 12
      ],
      [
        rdfs:label "PVA";
        schema:value "Poly(vinyl alcohol)";
        schema:position 13
      ],
      [
        rdfs:label "polyimide";
        schema:value "Polyimide";
        schema:position 14
      ],
      [
        rdfs:label "polyurethane";
        schema:value "Polyurethane";
        schema:position 15
      ],
      [
        rdfs:label "PLA";
        schema:value "Polylactic acid";
        schema:position 16
      ]
  ],
  [
    a spl:Argument ;
    sp:varName "AmountType" ;
    schema:option [
        rdfs:label "volume";
        schema:identifier <http://materialsmine.org/resource/VolumeFraction>;
        schema:position 1
      ],
      [
        rdfs:label "mass";
        schema:identifier <http://materialsmine.org/resource/MassFraction>;
        schema:position 2
      ]
  ],
  [
    a spl:Argument ;
    sp:varName "PropertyType" ;
    schema:option [
        rdfs:label "glass transition temperature";
        schema:identifier <http://materialsmine.org/resource/GlassTransitionTemperature>;
        schema:position 1
      ],
      [
        rdfs:label "elastic modulus";
        schema:identifier <http://materialsmine.org/resource/TensileModulus>;
        schema:position 2 
      ],
      [
        rdfs:label "tensile stress at break";
        schema:identifier <http://materialsmine.org/resource/TensileStressAtBreak>;
        schema:position 3
      ],
      [
        rdfs:label "elongation at break";
        schema:identifier <http://materialsmine.org/resource/ElongationAtBreak>;
        schema:position 4
      ]
  ];
  mmpq:replacement
  [
    sp:varName "FillerAmount";
    mmpq:subVar "AmountType" ; 
    mmpq:varFormat "${var}Fraction";
  ],
  [
    sp:varName "AttributeValue";
    mmpq:subVar "PropertyType" ;
    mmpq:varFormat "${var}";
  ].
